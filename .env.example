# ErgoVision backend runtime settings
ERGOVISION_API_HOST=0.0.0.0
ERGOVISION_API_PORT=8000
ERGOVISION_LOG_LEVEL=info

# Frontend URL displayed in startup logs
ERGOVISION_FRONTEND_URL=http://localhost:5174
ERGOVISION_FRONTEND_DEV_PORT=5174

# CORS (comma-separated origins)
ERGOVISION_CORS_ALLOWED_ORIGINS=http://localhost:5174,http://127.0.0.1:5174,http://localhost:8000,http://127.0.0.1:8000

# Camera defaults
ERGOVISION_CAMERA_INDEX=0
ERGOVISION_CAMERA_WIDTH=640
ERGOVISION_CAMERA_HEIGHT=480
ERGOVISION_TARGET_FPS=30

# Data and database
ERGOVISION_DATA_DIR=./data
ERGOVISION_DB_PATH=./data/wellness.db
ERGOVISION_DB_TIMEOUT_SECONDS=5
